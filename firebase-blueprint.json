{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's avatar URL" },
        "phone": { "type": "string", "description": "User's phone number" },
        "role": { "type": "string", "enum": ["coach", "client"], "description": "User's role" },
        "isActive": { "type": "boolean", "description": "Whether the client is currently active" },
        "isOnboarded": { "type": "boolean", "description": "Whether the client has completed onboarding" },
        "age": { "type": "number", "description": "User's age" },
        "emergencyContactName": { "type": "string", "description": "Emergency contact name" },
        "emergencyContactPhone": { "type": "string", "description": "Emergency contact phone number" },
        "formalDiagnosis": { "type": "string", "description": "User's formal diagnosis" },
        "schedulingConstraints": { "type": "string", "description": "User's scheduling constraints" },
        "parentName": { "type": "string", "description": "Parent/Guardian Name" },
        "parentPhone": { "type": "string", "description": "Parent/Guardian Phone" },
        "parentEmail": { "type": "string", "description": "Parent/Guardian Email" },
        "secondaryParentName": { "type": "string", "description": "Secondary Parent/Guardian Name" },
        "secondaryParentPhone": { "type": "string", "description": "Secondary Parent/Guardian Phone" },
        "secondaryParentEmail": { "type": "string", "description": "Secondary Parent/Guardian Email" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation time" },
        "reminderTemplate": { "type": "string", "description": "Custom reminder email template" }
      },
      "required": ["uid", "email", "role"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Coaching session details.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Google Calendar Event ID" },
        "title": { "type": "string", "description": "Session title" },
        "description": { "type": "string", "description": "Session description" },
        "startTime": { "type": "string", "format": "date-time", "description": "Session start time" },
        "endTime": { "type": "string", "format": "date-time", "description": "Session end time" },
        "clientEmail": { "type": "string", "format": "email", "description": "Client's email" },
        "clientUid": { "type": "string", "description": "Client's UID (if registered)" },
        "isExternal": { "type": "boolean", "description": "True if client is not registered" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"], "description": "Session status" },
        "remindersSent": { "type": "array", "items": { "type": "string" }, "description": "List of reminder types sent (e.g., '48h', '1h')" }
      },
      "required": ["id", "title", "startTime", "endTime", "clientEmail"]
    },
    "Document": {
      "title": "Document",
      "description": "Shared coaching materials.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "File name" },
        "url": { "type": "string", "format": "uri", "description": "Firebase Storage URL" },
        "ownerUid": { "type": "string", "description": "Coach's UID" },
        "sharedWithEmail": { "type": "string", "format": "email", "description": "Client's email" },
        "sharedWithUid": { "type": "string", "description": "Client's UID (if registered)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Upload time" }
      },
      "required": ["name", "url", "ownerUid", "sharedWithEmail"]
    },
    "AppointmentRequest": {
      "title": "Appointment Request",
      "description": "Session request from a client.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Client's UID" },
        "email": { "type": "string", "format": "email", "description": "Client's email" },
        "displayName": { "type": "string", "description": "Client's name" },
        "reason": { "type": "string", "description": "Reason for the session" },
        "desiredDateTime": { "type": "string", "format": "date-time", "description": "Requested date and time" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Request status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Request time" }
      },
      "required": ["uid", "email", "reason", "desiredDateTime", "status"]
    },
    "CoachNote": {
      "title": "Coach Note",
      "description": "Private notes about a client, visible only to the coach.",
      "type": "object",
      "properties": {
        "clientUid": { "type": "string", "description": "Client's UID" },
        "content": { "type": "string", "description": "The note content" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update time" }
      },
      "required": ["clientUid", "content"]
    },
    "Message": {
      "title": "Message",
      "description": "A message between coach and client.",
      "type": "object",
      "properties": {
        "senderUid": { "type": "string", "description": "UID of the sender" },
        "receiverUid": { "type": "string", "description": "UID of the receiver" },
        "content": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Time sent" },
        "isRead": { "type": "boolean", "description": "Whether the message has been read" },
        "type": { "type": "string", "enum": ["text", "system"], "description": "Message type" },
        "metadata": { "type": "object", "description": "Optional metadata (e.g., document info)" }
      },
      "required": ["senderUid", "receiverUid", "content", "createdAt", "isRead", "type"]
    },
    "PrivateNote": {
      "title": "Private Note",
      "description": "Metadata for a private session note stored in Google Drive.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Note title" },
        "driveFileId": { "type": "string", "description": "Google Drive File ID" },
        "webViewLink": { "type": "string", "format": "uri", "description": "Link to the Google Doc" },
        "clientUid": { "type": "string", "description": "Client's UID" },
        "coachUid": { "type": "string", "description": "Coach's UID" },
        "appointmentId": { "type": "string", "description": "Optional associated appointment ID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation time" }
      },
      "required": ["title", "driveFileId", "webViewLink", "clientUid", "coachUid", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A long-term goal for a client.",
      "type": "object",
      "properties": {
        "clientUid": { "type": "string", "description": "Client's UID" },
        "title": { "type": "string", "description": "Goal title" },
        "description": { "type": "string", "description": "Goal description" },
        "targetDate": { "type": "string", "format": "date-time", "description": "Target completion date" },
        "status": { "type": "string", "enum": ["active", "completed", "archived"], "description": "Goal status" },
        "progress": { "type": "number", "description": "Progress percentage (0-100)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation time" }
      },
      "required": ["clientUid", "title", "status", "progress", "createdAt"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A habit tracked by a client.",
      "type": "object",
      "properties": {
        "clientUid": { "type": "string", "description": "Client's UID" },
        "name": { "type": "string", "description": "Habit name" },
        "frequency": { "type": "string", "description": "Frequency (e.g., daily, weekly)" },
        "reportingType": { 
          "type": "string", 
          "enum": ["binary", "count", "minutes", "miles", "percent", "servings"],
          "description": "How the habit is reported"
        },
        "targetValue": { "type": "number", "description": "Target value for non-binary habits" },
        "streak": { "type": "number", "description": "Current streak" },
        "lastCompleted": { "type": "string", "format": "date-time", "description": "Last completion time" },
        "history": { "type": "object", "description": "Map of dates to completion status or numerical value" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation time" }
      },
      "required": ["clientUid", "name", "reportingType", "streak", "createdAt"]
    },
    "SyncConfig": {
      "title": "Sync Configuration",
      "description": "Dynamic scheduling settings for background tasks.",
      "type": "object",
      "properties": {
        "calendarSyncHours": { "type": "array", "items": { "type": "integer" }, "description": "EST hours to sync calendar" },
        "reminderStartHour": { "type": "integer", "description": "EST hour to start reminders" },
        "reminderEndHour": { "type": "integer", "description": "EST hour to end reminders" },
        "catchAllAfterEnd": { "type": "boolean", "description": "Whether to send evening reminders at the end hour" }
      },
      "required": ["calendarSyncHours", "reminderStartHour", "reminderEndHour", "catchAllAfterEnd"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Coaching sessions"
    },
    "/documents/{documentId}": {
      "schema": "Document",
      "description": "Shared documents"
    },
    "/requests/{requestId}": {
      "schema": "AppointmentRequest",
      "description": "Session requests"
    },
    "/coach_notes/{clientUid}": {
      "schema": "CoachNote",
      "description": "Private coach notes"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "2-way messaging between coach and client"
    },
    "/private_notes/{noteId}": {
      "schema": "PrivateNote",
      "description": "Metadata for private session notes in Drive"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Client goals"
    },
    "/habits/{habitId}": {
      "schema": "Habit",
      "description": "Client habits"
    },
    "/settings/sync_config": {
      "schema": "SyncConfig",
      "description": "Global sync and reminder settings"
    }
  }
}
