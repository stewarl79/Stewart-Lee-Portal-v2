# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Service Account (for Calendar Sync)
GOOGLE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# SMTP Configuration (for Reminders)
SMTP_HOST="mail.mrleeteaches.com"
SMTP_PORT="465"
SMTP_USER="reminder@mrleeteaches.com"
SMTP_PASS="your-email-password"
SMTP_SECURE="true"
SMTP_FROM="reminder@mrleeteaches.com"
SMTP_FROM_NAME="MrLeeTeaches"
SMTP_REPLY_TO="msustewart@gmail.com"
SMTP_REJECT_UNAUTHORIZED="true"
SMTP_DEBUG="false"

# Coach Information
COACH_EMAIL="msustewart@gmail.com"

# Google Drive Integration
GOOGLE_CLIENT_ID="your-client-id"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REDIRECT_URI="https://your-app.run.app/api/auth/google/callback"
GOOGLE_DRIVE_LIBRARY_FOLDER_ID="your-library-folder-id"
GOOGLE_DRIVE_CLIENTS_ROOT_FOLDER_ID="your-clients-root-folder-id"
GOOGLE_DRIVE_PRIVATE_NOTES_ROOT_FOLDER_ID="your-private-notes-root-folder-id"

# Application URL (for redirects)
APP_URL="https://portal.mrleeteaches.com"

